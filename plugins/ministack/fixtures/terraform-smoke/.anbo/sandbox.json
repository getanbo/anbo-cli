{
  "$schema": "https://raw.githubusercontent.com/getanbo/anbo-cli/main/plugins/ministack/schemas/sandbox.v2.schema.json",
  "schema_version": 2,
  "project": {
    "name": "anbo-terraform-smoke"
  },
  "terraform": {
    "roots": ["infra"],
    "variable_files": []
  },
  "data": {},
  "builds": {
    "lambda": {
      "context": ".",
      "inputs": ["lambda", "scripts/build-lambda.mjs"],
      "command": ["node", "scripts/build-lambda.mjs"],
      "outputs": ["infra/dist/smoke.zip"]
    },
    "runner": {
      "context": ".",
      "inputs": [".dockerignore", "Dockerfile", "package.json", "package-lock.json", "runner"],
      "dockerfile": "Dockerfile"
    }
  },
  "services": {
    "runner": {
      "build": "runner",
      "dynamodb_plane": "ministack",
      "healthcheck": {
        "type": "command",
        "command": ["node", "-e", "fetch('http://127.0.0.1:8080/healthz').then(r=>{if(!r.ok)process.exit(1)}).catch(()=>process.exit(1))"],
        "timeout_seconds": 30,
        "interval_seconds": 1
      }
    }
  },
  "tests": {
    "terraform-resources": {
      "command": ["node", "runner/smoke-resources.mjs"],
      "service": "runner",
      "depends_on": ["runner"],
      "inputs": [
        "acceptance-inputs/terraform-resources.txt",
        "runner/smoke-resources.mjs"
      ],
      "requires": ["terraform:infra"],
      "tags": ["acceptance", "terraform"],
      "cache": true,
      "timeout_seconds": 60,
      "default": true,
      "environment": {
        "ANBO_TEST_PROTOCOL": "jsonl-v1"
      }
    },
    "lambda-invoke": {
      "command": ["node", "runner/smoke-lambda.mjs"],
      "service": "runner",
      "depends_on": ["runner"],
      "inputs": [
        "acceptance-inputs/lambda-invoke.txt",
        "runner/smoke-lambda.mjs"
      ],
      "requires": ["terraform:infra"],
      "tags": ["acceptance", "lambda"],
      "cache": true,
      "timeout_seconds": 60,
      "default": true,
      "environment": {
        "ANBO_FORCE_TEST_FAILURE": "0",
        "ANBO_TEST_PROTOCOL": "jsonl-v1"
      }
    }
  },
  "ministack": {
    "image": "ministackorg/ministack@sha256:636c4ef52bff20e29f161d24e895359b2927f72a143d726792faa86160043ca9",
    "digest": "sha256:636c4ef52bff20e29f161d24e895359b2927f72a143d726792faa86160043ca9",
    "profile": "full",
    "persistence": true,
    "environment": {
      "LAMBDA_EXECUTOR": "local",
      "LOG_LEVEL": "INFO"
    }
  },
  "network": {
    "allow_hosts": [],
    "clone_egress": false
  },
  "adapters": {}
}
