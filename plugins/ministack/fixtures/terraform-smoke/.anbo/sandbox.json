{
  "$schema": "https://raw.githubusercontent.com/getanbo/anbo-plugin-ministack/v0.1.0/schemas/sandbox.v2.schema.json",
  "schema_version": 2,
  "project": {
    "name": "anbo-terraform-smoke"
  },
  "terraform": {
    "roots": ["infra"],
    "variable_files": []
  },
  "data": {},
  "builds": {
    "lambda": {
      "context": ".",
      "inputs": ["lambda", "scripts/build-lambda.mjs"],
      "command": ["node", "scripts/build-lambda.mjs"],
      "outputs": ["infra/dist/smoke.zip"]
    },
    "runner": {
      "context": ".",
      "inputs": [".dockerignore", "Dockerfile", "package.json", "package-lock.json", "runner"],
      "dockerfile": "Dockerfile"
    }
  },
  "services": {
    "runner": {
      "build": "runner",
      "dynamodb_plane": "ministack",
      "healthcheck": {
        "type": "command",
        "command": ["node", "-e", "fetch('http://127.0.0.1:8080/healthz').then(r=>{if(!r.ok)process.exit(1)}).catch(()=>process.exit(1))"],
        "timeout_seconds": 30,
        "interval_seconds": 1
      }
    }
  },
  "tests": {
    "terraform-smoke": {
      "command": ["node", "runner/smoke.mjs"],
      "service": "runner",
      "depends_on": ["runner"],
      "timeout_seconds": 60,
      "default": true,
      "environment": {
        "ANBO_TEST_PROTOCOL": "jsonl-v1"
      }
    }
  },
  "ministack": {
    "image": "ghcr.io/getanbo/anbo-ministack@sha256:cf29ce9cacd3982531b5f5bd48a7b46c10acaf4f44a10fb25831b3073c26b204",
    "digest": "sha256:cf29ce9cacd3982531b5f5bd48a7b46c10acaf4f44a10fb25831b3073c26b204",
    "profile": "full",
    "persistence": true,
    "environment": {
      "LAMBDA_EXECUTOR": "local",
      "LOG_LEVEL": "INFO"
    }
  },
  "network": {
    "allow_hosts": [],
    "clone_egress": false
  },
  "adapters": {}
}
