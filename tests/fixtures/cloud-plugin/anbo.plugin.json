{
  "schema_version": 1,
  "plugin_api": 1,
  "id": "anbo.cloud",
  "package": "@getanbo/plugin-cloud",
  "version": "0.1.0",
  "entrypoint": "./index.mjs",
  "engines": { "anbo": ">=0.2 <0.3", "node": ">=22" },
  "kinds": ["target", "commands"],
  "targets": [{
    "id": "cloud",
    "actions": ["configure", "deploy", "status", "test", "logs", "debug", "down", "capabilities"]
  }],
  "commands": ["cloud.login", "cloud.logout", "cloud.auth", "cloud.demo", "cloud.branch", "cloud.token", "cloud.sql", "cloud.report", "cloud.test-run", "cloud.test-status"],
  "config": { "schema": "./config.schema.json", "schema_version": 1 },
  "capabilities": ["acceptance.cloud"]
}
