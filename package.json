{
  "name": "anbo-cli-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run clean && npm run build --workspaces --if-present",
    "clean": "node scripts/clean.mjs",
    "test": "npm run build && node --test tests/unit/*.test.mjs && node scripts/acceptance.mjs",
    "test:unit": "npm run build && node --test tests/unit/*.test.mjs",
    "test:acceptance": "npm run build && node scripts/acceptance.mjs",
    "typecheck": "tsc -b --pretty false",
    "check": "npm run typecheck && npm test",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
