{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/getanbo/cli/main/schemas/plugin.v1.schema.json",
  "title": "Anbo Plugin Descriptor v1",
  "type": "object",
  "required": ["schema_version", "plugin_api", "id", "version", "engines", "targets"],
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": { "const": 1 },
    "plugin_api": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*$" },
    "name": { "type": "string", "minLength": 1 },
    "package": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$" },
    "entrypoint": { "type": "string", "minLength": 1 },
    "engines": {
      "type": "object",
      "required": ["anbo"],
      "properties": {
        "anbo": { "type": "string", "minLength": 1 },
        "node": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "kinds": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*$" },
          {
            "type": "object",
            "required": ["id", "actions"],
            "properties": {
              "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*$" },
              "actions": { "$ref": "#/$defs/actions" }
            },
            "additionalProperties": false
          }
        ]
      }
    },
    "actions": { "$ref": "#/$defs/actions" },
    "commands": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "config": {
      "type": "object",
      "required": ["schema", "schema_version"],
      "properties": {
        "schema": { "type": "string", "minLength": 1 },
        "schema_version": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "config_schema": { "type": "string", "minLength": 1 },
    "capabilities": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
  },
  "additionalProperties": false,
  "$defs": {
    "actions": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": ["configure", "deploy", "status", "test", "logs", "debug", "down", "capabilities", "cache"]
      }
    }
  }
}
